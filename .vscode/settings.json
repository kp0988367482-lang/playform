{
  "python.defaultInterpreterPath": "${workspaceFolder}/playform/apps/core/backend/.venv/Scripts/python.exe",
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": false,
  "python.terminal.activateEnvironment": true,
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.exclude": [
    "**/.venv/**",
    "**/__pycache__/**"
  ],
  "python.analysis.extraPaths": [
    "${workspaceFolder}/playform/apps/core/backend",
    "${workspaceFolder}/playform"
  ],
  "python.analysis.venvPath": "${workspaceFolder}/playform/apps/core/backend",
  "python.analysis.venv": ".venv",
  "python.analysis.typeCheckingMode": "basic",
  "claudeCodeChat.permissions.yoloMode": true
}
