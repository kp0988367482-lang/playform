# .env.production - 生產版 (優化和安全)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 應用環境
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ENV=production
DEBUG=false
LOG_LEVEL=ERROR

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API & 域名
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PLAYFORM_API=https://api.playform.app
FRONTEND_URL=https://playform.app
PLAYFORM_SECRET=${PLAYFORM_SECRET_PROD}  # 從 GitHub Secrets

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Firebase (生產項目)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
VITE_FIREBASE_API_KEY=${FIREBASE_API_KEY_PROD}
VITE_FIREBASE_PROJECT_ID=playform-prod
FIREBASE_PROJECT_ID=playform-prod

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI APIs (不暴露到前端)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
OPENAI_API_KEY=${OPENAI_API_KEY_PROD}
YOUTUBE_API_KEY=${YOUTUBE_API_KEY_PROD}
NOTION_API_KEY=${NOTION_API_KEY_PROD}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 資料庫 (Cloud SQL)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DATABASE_URL=${DATABASE_URL_PROD}
DB_POOL_MIN=10
DB_POOL_MAX=50

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# JWT (強化安全)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
JWT_SECRET=${JWT_SECRET_PROD}
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=168  # 7 天

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CORS & 安全
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ALLOWED_ORIGINS=https://playform.app,https://www.playform.app
SECURE_COOKIES=true
RATE_LIMIT=1000/hour

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI Agent (生產配置)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AGENT_ENABLED=true
AGENT_SCHEDULE=0 0 * * *  # 每日 00:00 UTC
AGENT_TIMEOUT=3600

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 監控和告警
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SENTRY_DSN=${SENTRY_DSN_PROD}
ALERT_EMAIL=team@playform.app
SLACK_WEBHOOK=${SLACK_WEBHOOK_PROD}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Google Cloud (部署)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GCP_PROJECT=playform-api-prod
CLOUD_RUN_REGION=us-central1
FIRESTORE_ENABLED=true
